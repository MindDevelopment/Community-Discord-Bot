# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Client ID (required for slash commands)
CLIENT_ID=your_client_id_here

# Guild ID (optional, for guild-specific commands during development)
GUILD_ID=your_guild_id_here

# Bot prefix (for legacy message commands, optional)
PREFIX=!

# Database path (optional, defaults to ./data/database.sqlite)
DB_PATH=./data/database.sqlite

# Log level: DEBUG, INFO, WARN, ERROR (optional, defaults to INFO)
LOG_LEVEL=INFO

# Setup mode: set to true to enable /setup-logs command (optional, defaults to false)
# After running /setup-logs, set back to false and re-deploy to hide the command
SETUP_ENABLED=false
